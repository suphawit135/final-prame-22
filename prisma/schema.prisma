// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Doctor {
  id             Int         @id @default(autoincrement())
  username       String      @unique
  password       String
  specialization String
  doctorNote     DoctorNote? @relation(fields: [doctorNoteId], references: [id])
  doctorNoteId   Int?
}

model User {
  id            Int          @id @default(autoincrement())
  username      String       @unique
  password      String
  doctorNote    DoctorNote?  @relation(fields: [doctorNoteId], references: [id])
  doctorNoteId  Int?
  healtRecord   HealtRecord? @relation(fields: [healtRecordId], references: [id])
  healtRecordId Int?
}

model DoctorNote {
  id        Int      @id @default(autoincrement())
  note      String
  createdAt DateTime @default(now())
  docterId  Doctor[]
  userId    User[]
}

model HealtRecord {
  id     Int      @id @default(autoincrement())
  type   String
  value  String
  date   DateTime @default(now())
  userId User[]
}
